generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NEON_GGSSMA_DATABASE_URL")
}

// --- Modelos de Usuário e Estrutura ---

model Usuario {
  id          String    @id @default(cuid())
  email       String    @unique
  nome        String?
  ativo       Boolean   @default(true)
  role        String    @default("user")
  clerkUserId String?   @unique

  regional   Regional? @relation(fields: [regionalId], references: [id])
  regionalId String?

  unidade    Unidade?  @relation(fields: [unidadeId], references: [id])
  unidadeId  String?

  @@map("usuarios")
}

model Regional {
  id       String    @id @default(cuid())
  nome     String    @unique
  usuarios Usuario[]
  @@map("regionais")
}

model Unidade {
  id       String    @id @default(cuid())
  nome     String    @unique
  usuarios Usuario[]
  @@map("unidades")
}


// --- Modelos do GGSSMA ---

enum AreaGGSSMA {
  SAUDE_OCUPACIONAL
  SEGURANCA_TRABALHO
  MEIO_AMBIENTE
}

enum PolaridadeIndicador {
  MAIOR_MELHOR
  MENOR_MELHOR
}

model IndicadorGGSSMA {
  id              String        @id @default(cuid())
  nome            String
  descricao       String?
  area            AreaGGSSMA
  regional        String?
  responsavel     String?
  macroProcesso   String?
  unidadeMedida   String?
  polaridade      PolaridadeIndicador
  formulaCalculo  String?

  resultados ResultadoMensalGGSSMA[]

  @@unique([nome, regional])
  @@map("ggssma_indicadores")
}

model ResultadoMensalGGSSMA {
  id            String      @id @default(cuid())
  indicadorId   String
  indicador     IndicadorGGSSMA @relation(fields: [indicadorId], references: [id])

  ano           Int
  mes           Int

  valorMeta     Float?
  valorReal     Float?
  observacao    String?

  @@unique([indicadorId, ano, mes])
  @@map("ggssma_resultados_mensais")
}
